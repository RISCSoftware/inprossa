	[240, 211, 214, 217, 220, 223, 228, 233, 237, 242, 247, 251, 254, 258, 261, 264, 267, 268, 268, 269, 269, 268, 266, 264, 261, 258, 255, 250, 246, 241, 236, 232, 228, 224, 220, 217, 214, 212, 211, 210, 211, 184, 188, 194, 202, 210, 219, 228, 238, 248, 256, 264, 272, 279, 285, 290, 294, 297, 299, 299, 299, 297, 294, 290, 285, 279, 272, 264, 256, 247, 237, 228, 220, 211, 202, 195, 189, 184, 181, 180, 181, 157, 165, 175, 187, 201, 214, 229, 243, 256, 268, 281, 291, 301, 309, 316, 322, 325, 328, 329, 328, 326, 322, 317, 310, 301, 291, 280, 268, 255, 242, 229, 214, 201, 188, 176, 165, 158, 152, 151, 152, 131, 143, 159, 177, 195, 214, 233, 250, 268, 285, 299, 312, 325, 335, 344, 350, 355, 358, 360, 358, 356, 351, 344, 335, 325, 312, 299, 284, 268, 250, 233, 215, 195, 177, 160, 144, 131, 124, 120, 123, 108, 126, 148, 171, 194, 217, 240, 262, 282, 302, 320, 335, 349, 361, 371, 379, 385, 388, 389, 388, 385, 379, 371, 361, 349, 336, 319, 302, 282, 262, 240, 218, 194, 171, 148, 126, 108, 95, 90, 95, 88, 114, 141, 169, 197, 225, 251, 276, 300, 321, 341, 359, 374, 388, 399, 408, 414, 418, 419, 418, 415, 408, 399, 388, 374, 359, 340, 321, 299, 276, 251, 225, 198, 170, 142, 114, 89, 68, 60, 69, 76, 108, 141, 174, 206, 236, 265, 293, 318, 343, 364, 383, 400, 415, 427, 437, 443, 448, 449, 448, 444, 437, 427, 416, 400, 383, 364, 342, 318, 292, 265, 237, 206, 175, 142, 109, 77, 46, 31, 47, 75, 111, 148, 183, 218, 250, 282, 311, 339, 365, 388, 409, 427, 442, 456, 465, 474, 477, 479, 478, 474, 466, 456, 442, 427, 408, 388, 364, 339, 311, 282, 251, 218, 184, 148, 112, 75, 37, 0, 38],
