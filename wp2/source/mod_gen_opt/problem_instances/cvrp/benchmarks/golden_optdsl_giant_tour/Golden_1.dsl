]

# Giant tour: permutation of customer IDs 1..N_CUSTOMERS
tour: DSList(N_CUSTOMERS, DSInt(1, N_CUSTOMERS))

# Route cuts: cut_after[pos] = 1 inserts a depot return after position pos
cut_after: DSList(N_CUSTOMERS, DSInt(0, 1))


def all_customers_visited(tour: DSList(N_CUSTOMERS, DSInt(1, N_CUSTOMERS))):
	# Each customer must appear exactly once in the tour.
	for c in range(1, N_CITIES):
		count = 0
		for pos in range(N_CUSTOMERS):
			if tour[pos] == c:
				count = count + 1
		assert count == 1


def route_count(cut_after: DSList(N_CUSTOMERS, DSInt(0, 1))):
	# Number of routes = cuts + 1; must not exceed N_VEHICLES.
	routes = 0
	for pos in range(N_CUSTOMERS):
		routes = routes + cut_after[pos]
	assert routes + 1 <= N_VEHICLES
	# No explicit cut needed at the last position (implicit depot return).
	assert cut_after[N_CUSTOMERS - 1] == 0


def capacity_constraints(
	tour: DSList(N_CUSTOMERS, DSInt(1, N_CUSTOMERS)),
	cut_after: DSList(N_CUSTOMERS, DSInt(0, 1))
):
	# Cumulative demand within each route must not exceed vehicle capacity.
	load = 0
	for pos in range(N_CUSTOMERS):
		load = load + DEMANDS[tour[pos]]
		assert load <= VEHICLE_CAPACITY
		if cut_after[pos] == 1:
			load = 0


def total_distance(
	tour: DSList(N_CUSTOMERS, DSInt(1, N_CUSTOMERS)),
	cut_after: DSList(N_CUSTOMERS, DSInt(0, 1))
):
	dist = 0
	# Depot to first customer.
	dist = dist + DISTANCE_MATRIX[DEPOT][tour[0]]
	# Traverse the tour; insert depot detours at cut positions.
	for pos in range(N_CUSTOMERS - 1):
		if cut_after[pos] == 1:
			dist = dist + DISTANCE_MATRIX[tour[pos]][DEPOT] + DISTANCE_MATRIX[DEPOT][tour[pos + 1]]
		else:
			dist = dist + DISTANCE_MATRIX[tour[pos]][tour[pos + 1]]
	# Last customer back to depot.
	dist = dist + DISTANCE_MATRIX[tour[N_CUSTOMERS - 1]][DEPOT]
	return dist


all_customers_visited(tour)
route_count(cut_after)
capacity_constraints(tour, cut_after)

objective: DSInt(0, MAX_ROUTE_COST) = total_distance(tour, cut_after)

minimize(objective)
