# --- Auxiliary Variables ---
# Leave empty, if not required.
# --- constraints ---
def no_overlap(
    items: Annotated[list[Item], Len(20, 20)],
    positions: Annotated[list[X_Y_Position], Len(20, 20)],
    assignments: Annotated[list[Annotated[int, Field(strict=True, ge=1, le=20)]], Len(20, 20)]
) -> None:
    for i in range(1, 21):
        for j in range(i + 1, 21):
            item_i : Item = items[i]
            pos_i : X_Y_Position = positions[i]
            box_i : int = assignments[i]

            item_j : Item = items[j]
            pos_j : X_Y_Position = positions[j]
            box_j : int = assignments[j]

            # Only check overlap if both items are in the same box
            if box_i == box_j:
                # Check if rectangles overlap
                assert (pos_i.x >= pos_j.x + item_j.width) or \
                       (pos_j.x >= pos_i.x + item_i.width) or \
                       (pos_i.y >= pos_j.y + item_j.height) or \
                       (pos_j.y >= pos_i.y + item_i.height)

