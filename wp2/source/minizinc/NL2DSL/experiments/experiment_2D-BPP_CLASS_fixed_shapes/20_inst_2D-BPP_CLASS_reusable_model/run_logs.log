# --- Auxiliary Variables ---
# Leave empty, if not required.
# --- constraints ---
def items_fit_exactly_in_box(items: Annotated[list[Item], Len(20, 20)],
                             assignments: Annotated[list[Annotated[int, Field(strict=True, ge=1, le=20)]], Len(20, 20)],
                             positions: Annotated[list[X_Y_Position], Len(20, 20)]):
    for i in range(1, N_ITEMS + 1):
        item: Item = items[i]
        pos: X_Y_Position = positions[i]
        box_id: Annotated[int, Field(strict=True, ge=1, le=20)] = assignments[i]

        # Ensure items fit within the box dimensions
        assert pos.x + item.width <= BOX_WIDTH
        assert pos.y + item.height <= BOX_HEIGHT

        # Ensure items do not overlap with other items in the same box
        for j in range(i + 1, N_ITEMS + 1):
            other_pos: X_Y_Position = positions[j]
            other_box_id: Annotated[int, Field(strict=True, ge=1, le=20)] = assignments[j]

            # Only check for overlap if both items are in the same box
            if box_id == other_box_id:
                # Check for non-overlapping condition
                assert (pos.x + item.width <= other_pos.x) or \
                       (other_pos.x + items[j].width <= pos.x) or \
                       (pos.y + item.height <= other_pos.y) or \
                       (other_pos.y + items[j].height <= pos.y)

