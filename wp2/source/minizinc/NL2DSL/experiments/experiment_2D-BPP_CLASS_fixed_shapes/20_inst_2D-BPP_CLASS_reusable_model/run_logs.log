def no_overlap(
    items: DSList(length=20, elem_type=Item),
    positions: DSList(length=20, elem_type=X_Y_Position),
    assignments: DSList(length=20, elem_type=DSInt(lb=1, ub=20))
) -> None:
    for i in range(1, 21):
        for j in range(i + 1, 21):
            item_i: Item = items[i]
            pos_i: X_Y_Position = positions[i]
            box_i: int = assignments[i]

            item_j: Item = items[j]
            pos_j: X_Y_Position = positions[j]
            box_j: int = assignments[j]

            # Check if both items are in the same box
            if box_i == box_j:
