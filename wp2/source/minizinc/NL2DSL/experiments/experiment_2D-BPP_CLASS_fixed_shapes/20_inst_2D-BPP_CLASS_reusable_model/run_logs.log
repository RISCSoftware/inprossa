# --- Auxiliary Variables ---
# Leave empty, if not required.
# --- constraints ---
def ensure_non_overlapping_and_fit_in_bin(
    items: Annotated[list[Item], Len(20, 20)],
    assignments: Annotated[list[Annotated[int, Field(strict=True, ge=1, le=20)]], Len(20, 20)],
    positions: Annotated[list[X_Y_Position], Len(20, 20)]
):
    for i in range(1, N_ITEMS + 1):
        item_i: Item = items[i]
        pos_i: X_Y_Position = positions[i]
        box_i: Annotated[int, Field(strict=True, ge=1, le=20)] = assignments[i]

        # Ensure item fits within the box dimensions
        assert pos_i.x + item_i.width <= BOX_WIDTH
        assert pos_i.y + item_i.height <= BOX_HEIGHT

        # Check for non-overlapping with all subsequent items
        for j in range(i + 1, N_ITEMS + 1):
            item_j: Item = items[j]
            pos_j: X_Y_Position = positions[j]
            box_j: Annotated[int, Field(strict=True, ge=1, le=20)] = assignments[j]

            # Only enforce non-overlapping if both items are in the same box
            if box_i == box_j:
                # Non-overlapping constraints
                assert (pos_i.x + item_i.width <= pos_j.x) or \
                       (pos_j.x + item_j.width <= pos_i.x) or \
                       (pos_i.y + item_i.height <= pos_j.y) or \
                       (pos_j.y + item_j.height <= pos_i.y)

