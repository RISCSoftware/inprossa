def items_fit_in_bin(
    items: Annotated[list[Item], Len(20, 20)],
    positions: Annotated[list[X_Y_Position], Len(20, 20)],
    assignments: Annotated[list[Annotated[int, Field(strict=True, ge=1, le=20)]], Len(20, 20)]
) -> None:
