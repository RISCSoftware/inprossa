def no_overlap(
    items: DSList(length=20, elem_type=Item),
    positions: DSList(length=20, elem_type=X_Y_Position),
    assignments: DSList(length=20, elem_type=DSInt(lb=1, ub=20))
) -> None:
    for i in range(1, 21):
        for j in range(i + 1, 21):
            # Only check overlap if both items are in the same box
            if assignments[i] == assignments[j]:
                # Check for non-overlapping on x-axis
                x_overlap : bool = not (positions[i].x + items[i].width <= positions[j].x or positions[j].x + items[j].width <= positions[i].x)
                # Check for non-overlapping on y-axis
                y_overlap : bool = not (positions[i].y + items[i].height <= positions[j].y or positions[j].y + items[j].height <= positions[i].y)

                # They must not overlap on both axes simultaneously
                assert not (x_overlap and y_overlap)

