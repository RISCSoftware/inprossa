def fit_items_in_box(items: DSList(length=20, elem_type=Item),
                     positions: DSList(length=20, elem_type=X_Y_Position),
                     box_assignments: DSList(length=20, elem_type=DSInt(lb=1, ub=20))) -> None:
    for i in range(1, N_ITEMS + 1):
        item: Item = items[i]
        pos: X_Y_Position = positions[i]
        box_id: int = box_assignments[i]

        # Only check constraints if item is assigned to a box (box_id > 0)
        # Items must fit within the box dimensions
        assert pos.x + item.width <= BOX_WIDTH
        assert pos.y + item.height <= BOX_HEIGHT
        assert pos.x >= 0
        assert pos.y >= 0

